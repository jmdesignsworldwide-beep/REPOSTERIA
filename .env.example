# ─────────────────────────────────────────────────────────────
#  Plantilla de variables de entorno de Supabase
#  Este archivo SÍ se sube a GitHub: solo documenta los NOMBRES,
#  nunca contiene valores reales.
#
#  Para usarlo en local: copia este archivo como ".env.local"
#  y rellena los valores desde Supabase → Settings → API.
# ─────────────────────────────────────────────────────────────

# Project URL  (público — se puede exponer al navegador)
NEXT_PUBLIC_SUPABASE_URL=

# anon / public key  (público — se puede exponer al navegador)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key  (SECRETA — SOLO servidor, NUNCA con prefijo NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
